@model IEnumerable<PrestivaCars.Data.Data.Vehicles.VehicleOffer>

@{
    ViewData["Title"] = "Vehicle offers";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h3 class="mb-1">Vehicle Offers</h3>
        <p class="text-muted mb-0">Manage public vehicle offers displayed in PrestivaCars.Web.</p>
    </div>

    <a asp-action="Create" class="btn btn-primary">
        Create New Offer
    </a>
</div>

<div class="card shadow-lg border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Offer</th>
                        <th>Vehicle</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Location</th>
                        <th>Featured</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@item.Title</div>
                                <div class="text-muted small">@item.Slug</div>
                            </td>

                            <td>
                                @item.Vehicle.Brand.Name @item.Vehicle.Model
                            </td>

                            <td>
                                @item.Vehicle.VehicleCategory.Name
                            </td>

                            <td>
                                <strong>@item.Price.ToString("C")</strong>
                            </td>

                            <td>
                                @item.Location
                            </td>

                            <td>
                                @if (item.IsFeatured)
                                {
                                    <span class="badge bg-primary">Featured</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Standard</span>
                                }
                            </td>

                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactive</span>
                                }
                            </td>

                            <td>
                                @item.CreatedAt.ToString("yyyy-MM-dd")
                            </td>

                            <td class="text-end">
                                <div class="btn-group">
                                    <a asp-action="Details"
                                           asp-route-id="@item.VehicleOfferId"
                                           class="btn btn-sm btn-outline-secondary">
                                        Details
                                    </a>

                                    <a asp-action="Edit"
                                           asp-route-id="@item.VehicleOfferId"
                                           class="btn btn-sm btn-outline-primary">
                                        Edit
                                    </a>

                                    <a asp-action="Delete"
                                           asp-route-id="@item.VehicleOfferId"
                                           class="btn btn-sm btn-outline-danger">
                                        Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>