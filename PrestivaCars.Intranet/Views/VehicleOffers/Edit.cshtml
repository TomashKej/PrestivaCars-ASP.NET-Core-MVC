@model PrestivaCars.Data.Data.Vehicles.VehicleOffer

@{
    ViewData["Title"] = "Edit Vehicle Offer";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h3 class="mb-1">Edit Vehicle Offer</h3>
        <p class="text-muted mb-0">
            Update offer content, linked vehicle, price and Portal visibility.
        </p>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Details" asp-route-id="@Model.VehicleOfferId" class="btn btn-outline-primary">
            Details
        </a>

        <a asp-action="Index" class="btn btn-outline-secondary">
            Back to List
        </a>
    </div>
</div>

<div class="card shadow-lg border-0">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="VehicleOfferId" />

            <div class="row g-3">

                <div class="col-md-8">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title"
                           class="form-control"
                           placeholder="E.g. 2020 BMW 3 Series M Sport" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Price" class="form-label"></label>
                    <input asp-for="Price"
                           class="form-control"
                           type="number"
                           step="0.01"
                           min="0"
                           placeholder="E.g. 15995.00" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="col-md-8">
                    <label asp-for="Slug" class="form-label"></label>
                    <input asp-for="Slug"
                           class="form-control"
                           placeholder="E.g. bmw-3-series-m-sport" />
                    <span asp-validation-for="Slug" class="text-danger"></span>
                    <div class="form-text">
                        If left empty, the slug will be generated from the title.
                    </div>
                </div>

                <div class="col-md-4">
                    <label asp-for="Location" class="form-label"></label>
                    <input asp-for="Location"
                           class="form-control"
                           placeholder="E.g. London" />
                    <span asp-validation-for="Location" class="text-danger"></span>
                </div>

                <div class="col-md-12">
                    <label asp-for="VehicleId" class="form-label"></label>
                    <select asp-for="VehicleId"
                            class="form-select"
                            asp-items="ViewBag.VehicleId">
                        <option value="">-- Select vehicle --</option>
                    </select>
                    <span asp-validation-for="VehicleId" class="text-danger"></span>
                    <div class="form-text">
                        Select the catalogue vehicle connected with this public offer.
                    </div>
                </div>

                <div class="col-md-12">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description"
                              class="form-control"
                              rows="7"
                              placeholder="Write the public offer description..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="col-md-12">
                    <div class="card border-0 bg-light mt-2">
                        <div class="card-body">
                            <h5 class="mb-2">Main Offer Image</h5>

                            <p class="text-muted small mb-3">
                                Update the image path manually or upload a new main image for this offer.
                            </p>

                            <div class="row g-3">
                                <div class="col-md-8">
                                    <label class="form-label">Image Path</label>

                                    <input type="text"
                                           name="mainImagePath"
                                           value="@ViewBag.MainImagePath"
                                           class="form-control"
                                           placeholder="/content/offers/example-image.jpg" />

                                    <div class="form-text">
                                        This path is stored in the database and used by the public Portal.
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Alt Text</label>

                                    <input type="text"
                                           name="mainImageAltText"
                                           value="@ViewBag.MainImageAltText"
                                           class="form-control"
                                           placeholder="Image description" />
                                </div>

                                <div class="col-md-12">
                                    <label class="form-label">Upload New Image</label>

                                    <input type="file"
                                           name="mainImageFile"
                                           class="form-control"
                                           accept=".jpg,.jpeg,.png,.webp" />

                                    <span class="text-danger" data-valmsg-for="mainImageFile"></span>

                                    <div class="form-text">
                                        If you upload a new image, it will replace the current main image path.
                                    </div>
                                </div>

                                @{
                                    var imagePath = ViewBag.MainImagePath as string;
                                    var portalBaseUrl = ViewBag.PortalBaseUrl as string ?? string.Empty;
                                    var previewUrl = string.Empty;

                                    if (!string.IsNullOrWhiteSpace(imagePath))
                                    {
                                        previewUrl = imagePath.StartsWith("http")
                                            ? imagePath
                                            : portalBaseUrl + imagePath;
                                    }
                                }

                                @if (!string.IsNullOrWhiteSpace(previewUrl))
                                {
                                    <div class="col-md-12">
                                        <label class="form-label">Current Image Preview</label>

                                        <div class="border rounded-4 overflow-hidden bg-white">
                                            <img src="@previewUrl"
                                                 alt="@ViewBag.MainImageAltText"
                                                 class="img-fluid w-100"
                                                 style="max-height: 280px; object-fit: cover;" />
                                        </div>

                                        <div class="form-text mt-2">
                                            Preview URL: @previewUrl
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-check mt-2">
                        <input asp-for="IsFeatured" class="form-check-input" />
                        <label asp-for="IsFeatured" class="form-check-label"></label>
                    </div>

                    <div class="form-text">
                        Featured offers can be highlighted on the public Portal.
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-check mt-2">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label"></label>
                    </div>

                    <div class="form-text">
                        Inactive offers are hidden from the public Portal.
                    </div>
                </div>

            </div>

            <div class="mt-4 d-flex gap-2 flex-wrap">
                <button type="submit" class="btn btn-primary">
                    Save Changes
                </button>

                <a asp-action="Details"
                       asp-route-id="@Model.VehicleOfferId"
                       class="btn btn-outline-primary">
                    Details
                </a>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}