@model PrestivaCars.Data.Data.Vehicles.VehicleOffer

@{
    ViewData["Title"] = "Create vehicle offer";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h3 class="mb-1">Create Vehicle Offer</h3>
        <p class="text-muted mb-0">Create a public offer based on an existing vehicle.</p>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">
        Back to List
    </a>
</div>

<div class="card shadow-lg border-0">
    <div class="card-body p-4">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" placeholder="E.g. BMW 320d M Sport Automatic" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Price" class="form-label"></label>
                    <input asp-for="Price" class="form-control" placeholder="18995" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="col-md-8">
                    <label asp-for="Slug" class="form-label"></label>
                    <input asp-for="Slug" class="form-control" placeholder="Optional - generated automatically if empty" />
                    <span asp-validation-for="Slug" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Location" class="form-label"></label>
                    <input asp-for="Location" class="form-control" placeholder="London" />
                    <span asp-validation-for="Location" class="text-danger"></span>
                </div>

                <div class="col-md-12">
                    <label asp-for="VehicleId" class="form-label"></label>
                    <select asp-for="VehicleId" class="form-select" asp-items="ViewBag.VehicleId">
                        <option value="">-- Select vehicle --</option>
                    </select>
                    <span asp-validation-for="VehicleId" class="text-danger"></span>
                </div>

                <div class="col-md-12">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description"
                              class="form-control"
                              rows="5"
                              placeholder="Describe the vehicle condition, equipment and key selling points..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <!-- IMAGE -->
                <div class="col-md-8">
                    <label class="form-label">Main Image</label>
                    <input type="file"
                           name="mainImageFile"
                           class="form-control"
                           accept=".jpg,.jpeg,.png,.webp"
                    />

                    <span class="text-danger field-validation-valid" data-valmsg-for="mainImageFile" data-valmsg-replace="true"></span>

                    <div class="form-text">
                        Allowed formats: JPG, JPEG, PNG, WEBP. Maximum size: 5 MB
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Image alt text</label>
                    <input type="text"
                           name="mainImageAltText"
                           class="form-control"
                           placeholder="BMW 320d M Sport" />
                    <div class="form-text">
                        Optional text used for accessibility.
                    </div>
                </div>

                <!-- Featured -->
                <div class="col-md-4">
                    <div class="form-check form-switch mt-4">
                        <input asp-for="IsFeatured" class="form-check-input" />
                        <label asp-for="IsFeatured" class="form-check-label"></label>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="form-check form-switch mt-4">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label"></label>
                    </div>
                </div>
            </div>

            <div class="mt-4 d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    Cancel
                </a>

                <button type="submit" class="btn btn-primary">
                    Create Offer
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}