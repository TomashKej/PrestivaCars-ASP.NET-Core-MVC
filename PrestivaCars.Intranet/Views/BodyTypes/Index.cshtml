@model IEnumerable<PrestivaCars.Data.Data.Catalog.BodyType>

@{
    ViewData["Title"] = "Body types";
}

<!-- PAGE HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1">Body types</h3>
        <p class="text-muted mb-0">Manage vehicle body types used in the catalogue.</p>
    </div>

    <a class="btn btn-outline-info" asp-action="Create">Add Brand</a>
</div>

<!-- Filter Card -->
<div class="card shadow-sm border mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Filters</h6>
        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#vehicleBodyTypesFilters">
            Toggle
        </button>
    </div>

    <div class="collapse" id="vehicleBodyTypesFilters">
        <div class="card-body">
            <form method="get">
                <div class="row g-3 justify-content-between align-items-center">
                    <div class="col-md-4">
                        <input type="text" name="searchString" class="form-control" placeholder="Search body type..." />
                    </div>

                    <div class="col-md-4 form-check form-switch">
                        <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                        <label class="form-check-label" for="switchCheckDefault">Display only active body types</label>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- TABLE CARD -->
<div class="card shadow-sm border-1">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="text-center align-middle">Name</th>
                        <th class="text-center align-middle">Status</th>
                        <th class="text-center align-middle">Action</th>
                    </tr>
                </thead>

                <tbody class="">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center align-middle fw-semibold">
                                @item.Name
                            </td>

                            <td class="text-center align-middle">
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                }
                            </td>

                            <td class="text-center align-middle">
                                <div class="btn-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.BodyTypeId" class="btn btn-sm btn-outline-primary">
                                        Edit
                                    </a>

                                    <a asp-action="Details" asp-route-id="@item.BodyTypeId" class="btn btn-sm btn-outline-secondary">
                                        Details
                                    </a>

                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger js-delete-btn"
                                            data-delete-url="@Url.Action("Delete", "BodyTypes", new { id = item.BodyTypeId })">
                                        Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- DELETE MODAL -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg" id="deleteModalContent"></div>
    </div>
</div>