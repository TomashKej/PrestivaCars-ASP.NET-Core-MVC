@model IEnumerable<PrestivaCars.Data.Data.Vehicles.Vehicle>

@{
    ViewData["Title"] = "Vehicles";
}

<!-- PAGE HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1">Vehicles</h3>
        <p class="text-muted mb-0">Manage, search and organise vehicles in the catalogue.</p>
    </div>
    <a class="btn btn-outline-info" asp-action="Create">
        Add Vehicle
    </a>
</div>

<!-- FILTER CARD -->
<div class="card shadow-sm border mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Filters</h6>
        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#vehicleFilters">
            Toggle
        </button>
    </div>

    <div class="collapse" id="vehicleFilters">
        <div class="card-body">
            <form method="get">
                <div class="row g-3">
                    <!-- SEARCH + CATEGORY -->
                    <div class="col-md-6">
                        <label class="form-label">Search :</label>
                        <input type="text" name="searchString" class="form-control" placeholder="Brand, model, title..." />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Category :</label>
                        <select name="categoryId" class="form-select">
                            <option value="">All categories</option>
                        </select>
                    </div>

                    <!-- FUEL TYPE + TRANSSMISION -->
                    <div class="col-md-6">
                        <label class="form-label">Fuel type :</label>
                        <select name="fuelTypeId" class="form-select">
                            <option value="">All fuel types</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Transmission :</label>
                        <select name="transmissionId" class="form-select">
                            <option value="">All transmission types</option>
                        </select>
                    </div>

                    <!-- YEAR -->
                    <div class="col-md-3">
                        <label class="form-label">Year from :</label>
                        <input type="number" name="yearFrom" class="form-control" value="2000" min="1885" max="@DateTime.Now.Year" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Year to :</label>
                        <input type="number" name="yearTo" class="form-control" value="@DateTime.Now.Year" min="1885" max="@DateTime.Now.Year" />
                    </div>

                    <!-- PRICE -->
                    <div class="col-md-3">
                        <label class="form-label">Price from :</label>
                        <input type="number" step="0.1" name="priceFrom" class="form-control" placeholder="E.g. 5000" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Price to :</label>
                        <input type="number" step="0.1" name="priceTo" class="form-control" placeholder="E.g. 5000" />
                    </div>

                    <!-- BUTTONS -->
                    <div class="col-12 d-flex gap-2 mt-2">
                        <button type="submit" class="btn btn-primary">Search</button>
                        <a asp-action="Index" class="btn btn-outline-warning">Clear filters</a>
                    </div>

                </div>
            </form>
        </div>
    </div>
</div>

<!-- TABLE CARD -->
<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="text-center align-middle">Brand</th>
                        <th class="text-center align-middle">Model</th>
                        <th class="text-center align-middle">Year</th>
                        <th class="text-center align-middle">Mileage</th>
                        <th class="text-center align-middle">Fuel</th>
                        <th class="text-center align-middle">Transmission</th>
                        <th class="text-center align-middle">Body</th>
                        <th class="text-center align-middle">Colour</th>
                        <th class="text-center align-middle">Engine (cc)</th>
                        <th class="text-center align-middle">Power (HP)</th>
                        <th class="text-center align-middle">VIN</th>
                        <th class="text-center align-middle">Reg. No.</th>
                        <th class="text-center align-middle">Category</th>
                        <th class="text-center align-middle">Status</th>
                        <th class="text-center align-middle">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.Brand)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Model)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.ProductionYear)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Mileage)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.FuelType)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.TransmissionType)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.BodyType)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Color)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.EngineCapacity)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.PowerHp)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Vin)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.RegistrationNumber)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.VehicleCategory.Name)
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="btn-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.VehicleId" class="btn btn-sm btn-outline-primary">Edit</a>
                                    <a asp-action="Details" asp-route-id="@item.VehicleId" class="btn btn-sm btn-outline-secondary">Details</a>
                                    <button type="button" class="btn btn-sm btn-outline-danger js-delete-btn" data-id="@item.VehicleId">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- DELETE MODAL -->
<div class="modal fade" id="deleteVehicleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content" id="deleteVehicleModalContent"></div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.js-delete-btn').forEach(button => {
            button.addEventListener('click', async function () {
                const vehicleId = this.getAttribute('data-id');

                const response = await fetch(`/Vehicles/Delete/${vehicleId}`);
                const html = await response.text();

                document.getElementById('deleteVehicleModalContent').innerHTML = html;

                const modalElement = document.getElementById('deleteVehicleModal');
                const modal = new bootstrap.Modal(modalElement);
                modal.show();
            });
        });
    </script>
}