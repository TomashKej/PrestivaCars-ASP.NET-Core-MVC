@model PrestivaCars.Data.Data.Vehicles.VehicleCategory

<div class="row g-3">

    <div class="col-md-6">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name"
               class="form-control"
               placeholder="E.g. Luxury, Sport, SUV" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Slug" class="form-label"></label>
        <input asp-for="Slug"
               class="form-control"
               placeholder="E.g. luxury-cars, sport-cars, suv" />
        <span asp-validation-for="Slug" class="text-danger"></span>
        <div class="form-text">
            Friendly URL value used in links, for example: suv or electric-cars.
        </div>
    </div>

    <div class="col-md-6">
        <label asp-for="Position" class="form-label"></label>
        <input asp-for="Position"
               class="form-control"
               type="number"
               min="0"
               placeholder="E.g. 1" />
        <span asp-validation-for="Position" class="text-danger"></span>
        <div class="form-text">
            Lower numbers are displayed first.
        </div>
    </div>

    <div class="col-md-6">
        <label asp-for="IconName" class="form-label"></label>
        <input asp-for="IconName"
               class="form-control"
               placeholder="E.g. bi bi-car-front, bi bi-truck" />
        <span asp-validation-for="IconName" class="text-danger"></span>
        <div class="form-text">
            Optional Bootstrap Icons CSS class used to display a category icon.
        </div>
    </div>

    <div class="col-md-12">
        <label asp-for="ImagePath" class="form-label"></label>
        <input asp-for="ImagePath"
               class="form-control"
               placeholder="E.g. /content/categories/suv.jpg" />
        <span asp-validation-for="ImagePath" class="text-danger"></span>
        <div class="form-text">
            Optional image path used as a category preview image.
        </div>
    </div>

    <div class="col-md-12">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description"
                  class="form-control"
                  rows="4"
                  placeholder="Short description of this vehicle category..."></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="col-md-12">
        <div class="form-check form-switch mt-2">
            <input asp-for="IsActive"
                   class="form-check-input"
                   role="switch" />
            <label asp-for="IsActive" class="form-check-label"></label>
        </div>
        <div class="form-text">
            Active categories are available for use in the vehicle catalogue.
        </div>
    </div>

</div>