@model PrestivaCars.Data.Data.Catalog.VehicleColour

<div class="modal-header border-0 pb-0">
    <h5 class="modal-title fw-semibold">Confirm deletion</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="modal-body pt-2">
    <p class="mb-3 text-muted">
        Are you sure you want to delete this colour from the catalogue?
    </p>

    <div class="p-3 rounded-3 bg-light border">
        <strong>@Model.ColourName</strong>
    </div>

    <p class="small text-muted mt-3 mb-0">
        This action will mark the colour as inactive.
    </p>
</div>

<div class="modal-footer border-0 pt-0">
    <form asp-action="Delete" method="post" class="d-flex gap-2">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.VehicleColourId" />

        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
            Cancel
        </button>

        <button type="submit" class="btn btn-danger">
            Delete colour
        </button>
    </form>
</div>