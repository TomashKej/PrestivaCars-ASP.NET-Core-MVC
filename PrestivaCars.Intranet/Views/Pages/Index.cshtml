@model IEnumerable<PrestivaCars.Data.Data.CMS.Page>

@{
    ViewData["Title"] = "CMS Pages";
}

<form method="post" id="bulkActionForm">
    @Html.AntiForgeryToken()

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h3 class="mb-1">CMS Pages</h3>
            <p class="text-muted mb-0">
                Manage public portal pages displayed in navigation, footer links and page content.
            </p>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button type="button"
                    class="btn btn-outline-danger"
                    id="bulkDeleteButton"
                    data-bulk-action="@Url.Action("BulkDelete", "Pages")"
                    data-bulk-type="delete"
                    data-entity-name="CMS page"
                    disabled>
                Delete Selected
            </button>

            <button type="button"
                    class="btn btn-outline-success"
                    id="bulkRestoreButton"
                    data-bulk-action="@Url.Action("BulkRestore", "Pages")"
                    data-bulk-type="restore"
                    data-entity-name="CMS page"
                    disabled>
                Restore Selected
            </button>

            <a asp-action="Create" class="btn btn-success">
                Add Page
            </a>
        </div>
    </div>

    <div class="card shadow-lg border-0">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="p-4">
                    <div class="alert alert-info mb-0">
                        No CMS pages have been created yet.
                    </div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 44px;">
                                    <input type="checkbox"
                                           class="form-check-input"
                                           id="selectAllCheckbox"
                                           title="Select all pages" />
                                </th>
                                <th>Page</th>
                                <th>Slug</th>
                                <th>Navigation</th>
                                <th>Position</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <input type="checkbox"
                                               class="form-check-input bulk-checkbox"
                                               name="selectedIds"
                                               value="@item.PageId"
                                               data-active="@item.IsActive.ToString().ToLower()" />
                                    </td>

                                    <td>
                                        <div class="fw-semibold">@item.Title</div>
                                        <div class="text-muted small">
                                            Menu title: @item.LinkTitle
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(item.ShortDescription))
                                        {
                                            <div class="text-muted small mt-1">
                                                @item.ShortDescription
                                            </div>
                                        }
                                    </td>

                                    <td>
                                        <code>@item.Slug</code>
                                    </td>

                                    <td>
                                        @if (item.ShowInNavigation)
                                        {
                                            <span class="badge bg-primary">Visible</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Hidden</span>
                                        }
                                    </td>

                                    <td>
                                        @item.Position
                                    </td>

                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Inactive</span>
                                        }
                                    </td>

                                    <td>
                                        @item.CreatedAt.ToString("dd MMM yyyy")
                                    </td>

                                    <td class="text-end">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details"
                                                   asp-route-id="@item.PageId"
                                                   class="btn btn-sm btn-outline-info">
                                                Details
                                            </a>

                                            <a asp-action="Edit"
                                                   asp-route-id="@item.PageId"
                                                   class="btn btn-sm btn-outline-primary">
                                                Edit
                                            </a>

                                            @if (item.IsActive)
                                            {
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-danger js-delete-btn"
                                                        data-delete-url="@Url.Action("Delete", "Pages", new { id = item.PageId })">
                                                    Delete
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-success js-restore-btn"
                                                        data-restore-url="@Url.Action("Restore", "Pages", new { id = item.PageId })">
                                                    Restore
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</form>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" id="deleteModalContent">
        </div>
    </div>
</div>

<div class="modal fade" id="restoreModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" id="restoreModalContent">
        </div>
    </div>
</div>

<div class="modal fade" id="bulkActionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-semibold" id="bulkActionModalTitle">
                    Confirm action
                </h5>

                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body pt-2">
                <p class="mb-3 text-muted" id="bulkActionModalMessage">
                    Are you sure you want to continue?
                </p>

                <div class="p-3 rounded-3 bg-light border">
                    <strong id="bulkActionModalCount">0 selected records</strong>
                    <div class="small text-muted mt-1" id="bulkActionModalInfo">
                        Selected records will be updated.
                    </div>
                </div>

                <p class="small text-muted mt-3 mb-0" id="bulkActionModalNote">
                    This operation uses the soft delete mechanism.
                </p>
            </div>

            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>

                <button type="submit"
                        class="btn"
                        id="bulkActionSubmitButton"
                        form="bulkActionForm"
                        formmethod="post">
                    Confirm
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/delete-modal.js" asp-append-version="true"></script>
    <script src="~/js/restore-modal.js" asp-append-version="true"></script>
    <script src="~/js/bulk-actions-modal.js" asp-append-version="true"></script>
}