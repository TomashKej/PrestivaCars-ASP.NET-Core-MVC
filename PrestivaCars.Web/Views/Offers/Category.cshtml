@model IEnumerable<PrestivaCars.Data.Data.Vehicles.VehicleOffer>

@{
    ViewData["Title"] = ViewBag.CategoryName ?? "Category";
}

<section class="prestiva-category-hero">
    <div class="container">
        <span class="prestiva-hero-label">Vehicle category</span>

        <h1>@ViewBag.CategoryName</h1>

        @if (!string.IsNullOrWhiteSpace(ViewBag.CategoryDescription as string))
        {
            <p>@ViewBag.CategoryDescription</p>
        }
        <!-- Search form for filtering offers within the category -->
        <form asp-controller="Offers"
              asp-action="Category"
              asp-route-id="@ViewBag.CategoryId"
              method="get"
              class="prestiva-search-form">

            <div class="prestiva-search-input-wrapper">
                <i class="bi bi-search"></i>

                <input type="text"
                       name="searchTerm"
                       value="@ViewBag.SearchTerm"
                       class="form-control"
                       placeholder="Search in this category by brand, model, fuel, colour or location..." />
            </div>

            <button type="submit" class="btn prestiva-search-btn mt-1">
                Search
            </button>

            <a asp-controller="Offers"
                   asp-action="Category"
                   asp-route-id="@ViewBag.CategoryId"
                   class="btn prestiva-clear-btn mt-1">
                Clear
            </a>
        </form>
    </div>
</section>

<section class="prestiva-offers-section">
    <div class="container">
        <div class="prestiva-results-header">
            <div>
                <h2>Available offers</h2>
                @if (!string.IsNullOrWhiteSpace(ViewBag.SearchTerm as string))
                {
                    <p>
                        @Model.Count() results found for "@ViewBag.SearchTerm.ToLower().Trim()" in @ViewBag.CategoryName
                    </p>
                }
                else
                {
                    <p>
                        @Model.Count() offers in this category
                    </p>
                }
            </div>

            <a asp-controller="Offers" asp-action="Index" class="btn btn-outline-secondary">
                All cars
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="alert alert-info">
                There are no active offers in this category.
            </div>
        }
        else
        {
            <div class="prestiva-offers-list">
                @foreach (var offer in Model)
                {
                    @await Html.PartialAsync("_OfferCard", offer)
                }
            </div>
        }
    </div>
</section>