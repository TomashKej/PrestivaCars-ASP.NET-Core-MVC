<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PrestivaCars.Web</title>
    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PrestivaCars.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/offers.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <!-- HEADER -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-light">
            <div class="container-fluid prestiva-navbar-container">
                <!-- LEFT LOGO SIDE + MENU -->
                    @* <a class="navbar-brand prestiva-brand me-4" asp-area="" asp-controller="Home" asp-action="Index">
                        <img src="~/content/appLogo/LogoV1Smaller.jpg" alt="PrestivaCars logo" class="prestiva-logo" />
                    </a> *@

                <a class="navbar-brand prestiva-brand me-4" asp-controller="Home" asp-action="Index">
                    <img src="~/content/appLogo/LogoV1Smaller.jpg" alt="PrestivaCars logo" class="prestiva-logo" />
                </a>
                    <button class="navbar-toggler ms-auto" 
                            type="button" 
                            data-bs-toggle="collapse" 
                            data-bs-target="#mainNavbar" 
                            aria-controls="mainNavbar"
                            aria-expanded="false" 
                            aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav prestiva-main-nav align-items-lg-center mx-lg-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Offers" asp-action="Index">
                                Browse Cars
                            </a>
                        </li>

                        @await Component.InvokeAsync("PagesMenu")
                    </ul>

                    <!-- RIGHT SIDE: saved + profile -->
                    <div class="d-flex align-items-center prestiva-actions">
                        <a href="#"
                               class="prestiva-action-btn prestiva-action-btn-badge"
                               aria-label="Saved offers"
                               title="Saved offers">
                            <i class="bi bi-bookmark-heart"></i>
                            <span class="prestiva-action-badge">0</span>
                        </a>

                        <a href="#"
                               class="prestiva-action-btn"
                               aria-label="Profile"
                               title="Profile">
                            <i class="bi bi-person-circle"></i>
                        </a>

                    </div>
                </div>
                </div>
        </nav>

        <!-- The additional navbar used to jump between catwgories -->
        <div class="prestiva-category-bar">
            <div class="container">
                <div class="prestiva-category-bar-inner">
                    <span class="prestiva-category-label">
                        Explore by type
                    </span>

                    <ul class="prestiva-category-menu">
                        <li>
                            <a asp-controller="Offers" asp-action="Index">
                                All cars
                            </a>
                        </li>

                        @await Component.InvokeAsync("VehicleCategoriesMenu")
                    </ul>
                </div>
            </div>
        </div>
    </header>

    <!-- MAIN CONTENT -->
    <div class="container flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="prestiva-footer">
        <div class="container">
            <div class="prestiva-footer-main">
                <!-- LEFT -->
                <div class="prestiva-footer-column prestiva-footer-about">
                    <a asp-area=""
                           asp-controller="Home"
                           asp-action="Index"
                           class="d-inline-block mb-3">
                        <img src="~/content/appLogo/LogoV1Smaller.jpg"
                             alt="PrestivaCars logo"
                             class="prestiva-footer-logo" />
                    </a>

                    <p class="prestiva-footer-text">
                        PrestivaCars is a modern car sales platform designed to provide
                        a seamless and reliable experience for buying and selling vehicles.
                    </p>

                    <div class="prestiva-footer-links-inline">
                        <a asp-area="" asp-controller="Pages" asp-action="Details" asp-route-slug="faq">FAQ</a>
                        <a href="mailto:contact@prestivacars.com">Contact</a>
                    </div>
                </div>

                <!-- CENTER -->
                <div class="prestiva-footer-column prestiva-footer-navigation">
                    <h5 class="prestiva-footer-title">Quick Links</h5>

                    <ul class="prestiva-footer-list">
                        <li>
                            <a asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li>
                            <a asp-area="" asp-controller="Offers" asp-action="Index">Browse Cars</a>
                        </li>
                        <li>
                            <a asp-area="" asp-controller="Pages" asp-action="Details" asp-route-slug="about-us">About Us</a>
                        </li>
                        <li>
                            <a asp-area="" asp-controller="Pages" asp-action="Details" asp-route-slug="faq">Help & FAQs</a>
                        </li>
                    </ul>
                </div>

                <!-- RIGHT -->
                <div class="prestiva-footer-column prestiva-footer-support">
                    <h5 class="prestiva-footer-title">Legal & Support</h5>

                    <ul class="prestiva-footer-list">
                        <li>
                            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                        </li>
                        <li>
                            <a asp-area="" asp-controller="Home" asp-action="Privacy">Terms & Conditions</a>
                        </li>
                        <li>
                            <a asp-area="" asp-controller="Home" asp-action="Privacy">Cookie Policy</a>
                        </li>
                        <li>
                            <a href="mailto:contact@prestivacars.com">contact@prestivacars.com</a>
                        </li>
                    </ul>
                </div>
            </div>

            <hr class="prestiva-footer-divider" />

            <!-- Bottom -->
            <div class="prestiva-footer-bottom">
                <p class="mb-0">
                    &copy; 2026 PrestivaCars. All rights reserved.
                </p>

                <div class="prestiva-footer-bottom-links">
                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Terms</a>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Cookies</a>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
