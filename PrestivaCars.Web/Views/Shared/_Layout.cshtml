<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PrestivaCars.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PrestivaCars.Web.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <!-- HEADER -->
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid prestiva-navbar-container">
                <!-- LEFT LOGO SIDE + MENU -->
                <div class="d-flex align-items-center">
                    <a class="navbar-brand prestiva-brand me-4" asp-area="" asp-controller="Home" asp-action="Index">
                        <img src="~/content/appLogo/LogoV1Smaller.jpg" alt="PrestivaCars logo" class="prestiva-logo" />
                    </a>
                    
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <ul class="navbar-nav ms-auto">
                        @await Html.PartialAsync("_References", (IEnumerable<PrestivaCars.Data.Data.CMS.Page>)ViewBag.PageModel)
                    </ul>
                </div>
                <!-- RIGHT SIDE: saved + profile -->
                <div class="d-flex align-items-center prestiva-actions">
                    <a href="#" class="prestiva-icon-link" aria-label="Saved cars">
                        <span class="prestiva-icon">&#10084;</span>
                    </a>

                    <a href="#" class="prestiva-icon-link ms-3" aria-label="User profile">
                        <span class="prestiva-icon">&#128100;</span>
                    </a>
                </div>
            </div>
        </nav>
    </header>

    <!-- MAIN CONTENT -->
    <div class="container flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="prestiva-footer border-top text-muted">
        <div class="container">
            <div class="row g-4">
            <!-- LEFT -->
                <div class="col-lg-4 col-md-6">
                    <div class="prestiva-footer-brand">
                        <a asp-area="" asp-controller="Home" asp-action="Index" class="d-inline-block mb-3 ">
                            <img src="~/content/appLogo/LogoV1Smaller.jpg" alt="PrestivaCars logo" class="prestiva-footer-logo" />
                        </a>

                        <p class="prestiva-footer-text">
                            PrestivaCars is a modern car sales platform designed to provide 
                            a seamless and reliable experience for buying and selling vehicles.
                        </p>

                        <div class="prestiva-footer-links-inline">
                            <a asp-area="" asp-controller="Home" asp-action="">FAQ</a>
                            <a asp-area="" asp-controller="Home" asp-action="">Contact</a>
                        </div>
                    </div>
                </div>

                <!-- CENTER -->
                <div class="col-lg-4 col-md-6">
                    <h5 class="prestiva-footer-title">Quick Links</h5>
                    <ul class="prestiva-footer-list">
                        <li>
                            <a asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li>
                            <a asp-area="" asp-controller="Home" asp-action="Privacy">Browse Cars</a>
                        </li>
                        <li>
                            <a asp-area="" asp-controller="Home" asp-action="Privacy">About Us</a>
                        </li>
                        <li>
                            <a asp-area="" asp-controller="Home" asp-action="Privacy">Help & FAQs</a>
                        </li>
                    </ul>
                </div>

                <!-- RIGHT -->
                <div class="col-lg-4 col-md-12">
                    <h5 class="prestiva-footer-title">Legal & Support</h5>
                    <ul class="prestiva-footer-list">
                        <li>
                            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                        </li>
                        <li>
                            <a asp-area="" asp-controller="Home" asp-action="Privacy">Terms & Conditions</a>
                        </li>
                        <li>
                            <a asp-area="" asp-controller="Home" asp-action="Privacy">Cookie Policy</a>
                        </li>
                        <li>
                            <a href="mailto:contact@prestivacars.com">contact@prestivacars.com</a>
                        </li>
                    </ul>
                </div>
            </div>

            <hr/>

            <!-- Bottom -->
            <div class="prestiva-footer-bottom d-flex flex-column flex-md-row justify-content-between align-items-center">
                <p class="mb-2 mb-md-0">
                    &copy; 2026 PrestivaCars. All rights reserved.
                </p>

                <div class="prestiva-footer-bottom-links">
                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Terms</a>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Cookies</a>
                </div>
            </div>

        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
