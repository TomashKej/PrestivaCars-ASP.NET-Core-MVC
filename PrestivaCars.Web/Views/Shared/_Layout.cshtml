<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PrestivaCars.Web</title>
    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PrestivaCars.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/offers.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <!-- HEADER -->
    <header>
        @await Component.InvokeAsync("Navbar")

        <!-- The additional navbar used to jump between catwgories -->
        <div class="prestiva-category-bar">
            <div class="container">

                <!-- Mobile phone colapse menu -->
                <button class="prestiva-category-toggle d-md-none"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mobileCategoryMenu"
                        aria-expanded="false"
                        aria-controls="mobileCategoryMenu">
                    <span>Explore by type</span>
                    <i class="bi bi-chevron-down"></i>
                </button>

                <!-- categories bar -->
                <div class="collapse d-md-block" id="mobileCategoryMenu">
                    <div class="prestiva-category-bar-inner">
                        <span class="prestiva-category-label d-none d-md-inline">
                            Explore by type
                        </span>

                        <ul class="prestiva-category-menu">
                            <li>
                                <a asp-controller="Offers" asp-action="Index">
                                    All cars
                                </a>
                            </li>

                            @await Component.InvokeAsync("VehicleCategoriesMenu")
                        </ul>
                    </div>
                </div>

            </div>
        </div>
    </header>

    <!-- MAIN CONTENT -->
    <div class="container flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    @await Component.InvokeAsync("Footer")

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
